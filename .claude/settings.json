{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "バージョン番号を更新中...",
            "command": "bash /home/user/stock-dialy/.claude/bump-version.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "env": {
      "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
      "ENABLE_TOOL_SEARCH": "true"
  }
}
