# Django Core Settings
# ======================
# SECURITY WARNING: keep the secret key used in production secret!
# Generate a new secret key with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Database Configuration
# ======================
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
# ===================
# Gmail SMTP settings（USE_SES=False のとき必須）
EMAIL_HOST_PASSWORD=your_gmail_app_password_here

# AWS (S3 / SES)
# ==============
# 本番で S3 配信・SES 送信を使うときだけ True にする（VPS/ローカルは False のまま）。
# 認証情報は EC2 の IAM インスタンスプロファイルから自動取得するため、
# アクセスキー/シークレットはここに置かない。
USE_S3=False
USE_SES=False
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-northeast-1
AWS_S3_CUSTOM_DOMAIN=               # CloudFront ドメイン（任意。未設定なら S3 標準ドメイン）
AWS_SES_REGION_NAME=ap-northeast-1

# ドメイン取得前のデプロイ検証用（検証時のみ True、本番は False）
HTTP_ONLY=False
EXTRA_CSRF_ORIGINS=               # 例: http://<EIP>（カンマ区切りで複数可）

# External API Keys
# =================
# Google Gemini AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# EDINET API Key (Japanese financial disclosure system)
# Get your API key from: https://disclosure2.edinet-fsa.go.jp/
EDINET_API_KEY=your_edinet_api_key_here

# Earnings Calendar API (決算予定API / EDINET DB)
# 商用利用可能な無料プラン（100リクエスト/日）。決算予定（/v1/calendar）を日次取得。
# サインアップ・APIキー・エンドポイント/認証ヘッダーの正確な仕様は提供元を確認:
#   https://edinetdb.com/docs/api
# キー未設定なら決算予定の同期バッチは何もせずスキップ（誤って外部APIを叩かない）。
EARNINGS_CALENDAR_API_KEY=your_earnings_calendar_api_key_here
# 以下は提供元仕様に合わせて必要な場合のみ上書き（既定で動かない場合に調整）
# EARNINGS_CALENDAR_API_BASE_URL=https://edinetdb.com
# EARNINGS_CALENDAR_API_PATH=/v1/calendar
# EARNINGS_CALENDAR_API_AUTH_HEADER=X-API-Key
# EARNINGS_CALENDAR_API_AUTH_SCHEME=Bearer

# Payment Processing (Stripe)
# ============================
# Uncomment and configure if using Stripe payments
# STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Redis Configuration (if needed for caching)
# ===========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# Push Notifications (Web Push / VAPID)
# ======================================
# VAPIDキーペアの生成方法:
#   pip install py-vapid
#   vapid --gen
# または:
#   python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print('Public:', v.public_key); print('Private:', v.private_key)"
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_ADMIN_EMAIL=your-admin-email@example.com
